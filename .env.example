# ── Dirección del sitio / HTTPS ──────────────────────────────────
# Local:      http://localhost   → HTTP plano, sin certificado.
# Producción: musix.midominio.com → HTTPS automático (Let's Encrypt).
SITE_ADDRESS=http://localhost
ACME_EMAIL=admin@example.com

# ── Base de datos ────────────────────────────────────────────────
POSTGRES_USER=musix
POSTGRES_PASSWORD=change-me-in-setup
POSTGRES_DB=musix
# Backend de metadatos: "sql" (SQLModel: SQLite en dev, Postgres en docker) o
# "dynamodb" (preparación para producción; adaptador aún stub).
DB_BACKEND=sql
# DynamoDB (solo si DB_BACKEND=dynamodb).
DYNAMODB_REGION=eu-west-1
# Para DynamoDB local (amazon/dynamodb-local): http://localhost:8001
DYNAMODB_ENDPOINT_URL=
DYNAMODB_TABLE_PREFIX=musix_

# ── Backend ──────────────────────────────────────────────────────
# Clave para firmar JWT. setup.sh la genera automáticamente si está vacía.
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=10080
# Permitir registro abierto de nuevos usuarios (true/false).
ALLOW_REGISTRATION=true
# Desactiva login durante el desarrollo (todo como usuario "dev", rol admin).
# Poner en false antes de exponer en producción.
AUTH_DISABLED=true
# Landing page pública (registro/login). Desactivada en dev; activar en producción.
LANDING_ENABLED=false

# ── Administrador inicial ────────────────────────────────────────
# Si ambos están definidos, al arrancar se crea/asegura un usuario con rol "admin".
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── Almacenamiento de ficheros (.musix, originales) ──────────────
# "local" (disco, por defecto en dev) o "s3" (S3 / S3-compatible).
STORAGE_BACKEND=local
# Almacenamiento S3 (solo si STORAGE_BACKEND=s3).
S3_BUCKET=
S3_REGION=eu-west-1
# Endpoint S3-compatible (MinIO, etc.). Vacío para AWS S3 real.
S3_ENDPOINT_URL=
# Prefijo opcional dentro del bucket.
S3_PREFIX=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Audio / bancos de sonido ─────────────────────────────────────
# Carpeta de bancos de sonido dentro del contenedor (bind-mount de ./soundbanks).
# Se descargan a mano con: scripts/fetch-soundbanks.sh
SOUNDBANKS_DIR=/soundbanks
