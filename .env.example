# ── Audio / bancos de sonido ─────────────────────────────────────
# Carpeta de bancos de sonido dentro del contenedor (bind-mount de ./soundbanks).
# Se descargan a mano con: scripts/fetch-soundbanks.sh
SOUNDBANKS_DIR=/soundbanks

# ── Secret key for JWT tokens ──────────────────────────────
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Admin credentials ─────────────────────────────────────
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ── SMTP config (contact form) ────────────────────────────
SMTP_HOST="email-smtp.us-east-1.amazonaws.com"
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=contacto@mu6.es
SMTP_FROM_NAME="Musix"
SMTP_STARTTLS=true
SMTP_SSL=false
MAIL_TO=


# ── AWS DynamoDB ──────────────────────────────────────────
AWS_REGION=
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
DYNAMODB_TABLE=
S3_BUCKET_NAME=

# ─── Captcha (Cloudflare Turnstile) ───────────────────────
CAPTCHA_SITE_KEY=
CAPTCHA_SECRET_KEY=

# ─── Google OAuth2 login ───────────── # https://mu6.es/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── DynamoDB endpoint (dev) ───────────────────────────────
# En desarrollo apunta a DynamoDB Local (docker-compose). En AWS real, dejar vacío.
DYNAMODB_ENDPOINT_URL=http://dynamodb:8000

# ── Flujo público / URLs ──────────────────────────────────
# URL pública del frontend: enlaces de email y redirect de Google OAuth.
PUBLIC_BASE_URL=http://localhost
# Orígenes permitidos por CORS (coma-separados).
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ALLOW_REGISTRATION=true

# ── Almacenamiento / caché ────────────────────────────────
# Caché local de ficheros de proyecto (S3 es la fuente de verdad). TTL en días.
CACHE_TTL_DAYS=7
# Prefijo de los soundbanks dentro del bucket S3.
SOUNDBANKS_S3_PREFIX=soundbanks

# ── Caddy (reverse proxy / HTTPS) ─────────────────────────
SITE_ADDRESS=http://localhost
ACME_EMAIL=
