# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/

# Node
node_modules/
dist/
.vite/
*.local

# Env / secrets
.env
.env.*
!.env.example

# Data
data/
*.sqlite
*.db

# Bancos de sonido: se descargan a mano (scripts/fetch-soundbanks.sh), no se versionan.
# Solo se versionan el catálogo y el README de la carpeta.
soundbanks/*
!soundbanks/README.md
!soundbanks/manifest.json

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Fork de AlphaTab (vendor/): NO se versiona. Solo vive en local para poder
# recompilar el .tgz cuando se toque el fork. La web consume el artefacto ya
# construido apps/web/alphatab-fork.tgz (ese sí versionado). Ver docs/FORK.md.
vendor/

# Planificación interna (no se publica).
PLAN.md
